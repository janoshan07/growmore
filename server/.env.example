# ─────────────────────────────────────────────────────────────
#  Grow More — Server Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# MongoDB — use your local URI or a MongoDB Atlas connection string
# Local:  mongodb://localhost:27017/growmore
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/growmore
MONGO_URI=mongodb://localhost:27017/growmore

# JWT — generate a strong random string (min 32 chars)
# Example: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars
JWT_EXPIRE=30d

# Frontend origin (for CORS)
CLIENT_URL=http://localhost:5173
